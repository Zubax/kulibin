CAPI=2:
name: zubax:kulibin:nco:0
description: Numerically controlled oscillator

filesets:
  rtl:
    files:
      - hdl/nco.v
    file_type: verilogSource
  tb:
    files:
      - tb/nco_tb.v
    file_type: verilogSource

targets:
  default:
    filesets: [rtl]
  sim:
    filesets: [rtl, tb]
    toplevel: nco_tb
    default_tool: icarus
    tools:
      icarus:
        iverilog_options: [-Wall, -Wno-timescale]
